{
  "name": "next-boilerplate",
  "version": "0.1.0",
  "author": {
    "name": "raja",
    "email": "raja.rakoto7@gmail.com"
  },
  "description": "Personnal boilerplate and starter for Next.js project",
  "homepage": "https://github.com/RajaRakoto/next-boilerplate",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS='--inspect' next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --testPathIgnorePatterns tests/ignore",
    "eslint": "eslint --ext .js,.jsx,.ts,.tsx --ignore-path .eslintignore .",
    "pkg-check": "npm-check",
    "pkg-upgrade": "npm-check -u",
    "format-check": "prettier --check --ignore-path .prettierignore .",
    "format-fix": "prettier --write --ignore-path .prettierignore .",
    "sseo-watch": "grunt --gruntfile sass-eo-cli.js watch-sass",
    "sseo-docs": "grunt --gruntfile sass-eo-cli.js sseo-docs",
    "sseo-magic": "grunt --gruntfile sass-eo-cli.js magic-docs",
    "sseo-buttons": "grunt --gruntfile sass-eo-cli.js buttons-maker"
  },
  "engines": {
    "node": ">=14.0.0",
    "pnpm": ">=8.0.0"
  },
  "resolutions": {
    "webpack": "^5"
  },
  "dependencies": {
    "@types/node": "20.2.5",
    "@types/react": "18.2.8",
    "@types/react-dom": "18.2.4",
    "next": "13.4.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "typescript": "5.0.4"
  },
  "devDependencies": {
    "@raja_rakoto/sass-eo": "^1.8.3",
    "@types/jest": "^29.5.2",
    "@typescript-eslint/eslint-plugin": "^5.59.9",
    "@typescript-eslint/parser": "^5.59.9",
    "axios-mock-adapter": "^1.21.4",
    "babel-loader": "^9.1.2",
    "cross-env": "^7.0.3",
    "eslint": "^8.42.0",
    "eslint-config-next": "^13.4.4",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "grunt": "^1.6.1",
    "grunt-contrib-sass": "^2.0.0",
    "grunt-contrib-watch": "^1.1.0",
    "grunt-shell": "^4.0.0",
    "jest": "^29.5.0",
    "load-grunt-tasks": "^5.1.0",
    "prettier": "^2.8.8",
    "ts-jest": "^29.1.0"
  }
}
